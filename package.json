{
  "name": "adri-portfolio-front",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:adri-portfolio-front": "node dist/adri-portfolio-front/server/server.mjs"
